# App (loaded by app.py)
APP_NAME=qa-chatbot
ENVIRONMENT=development
DEBUG=false
# Set to true for full-quality MAP-RPE runs (~375 LLM calls per calibration).
# False (default) uses the lite tier (~94 calls, 1/4 cost) for dev/staging.
PRODUCTION_APPLICATION=false
API_V1_PREFIX=/api/v1
# Allowed CORS origins (JSON list). Set your real frontend origin(s) in production. Do NOT use "*".
CORS_ORIGIN=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/qa_chatbot
POSTGRES_PASSWORD=postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6380/0
REDIS_TTL_SECONDS=3600

# LLM
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_MODEL=openai/gpt-4o-mini
COUNCIL_MODELS=["claude-sonnet-4-20250514", "gpt-4o"]

# Supabase Auth (all four required — see src/app/config/supabase.py)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Request hardening
MAX_REQUEST_BODY_BYTES=1048576
REQUEST_TIMEOUT_SECONDS=60

# Sentry — leave blank to disable error tracking (safe for local dev)
SENTRY_DSN=

# GlitchTip — leave blank to disable error proxy endpoint (safe for local dev)
GLITCHTIP_API_URL=
GLITCHTIP_API_TOKEN=

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_BUCKET_NAME=promptly
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
